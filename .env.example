# ===========================================================================
# Whaticket — production stack environment
# ---------------------------------------------------------------------------
# Used by: docker-compose.prod.yaml
# Copy to .env and fill every variable. Defaults marked "change-me" MUST
# be replaced before going live; the stack will boot with them but is not
# safe.
# ===========================================================================

# --- Image tags ------------------------------------------------------------
# Pin to specific tags in CI; "latest" is acceptable for local prod tests.
BACKEND_TAG=latest
WORKER_TAG=latest
FRONTEND_TAG=latest

# --- Public hostnames (DNS records must point at the Traefik host) ---------
BACKEND_HOST=api.example.com
FRONTEND_HOST=app.example.com
MINIO_HOST=storage.example.com

# --- Let's Encrypt ---------------------------------------------------------
ACME_EMAIL=ops@example.com

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=whaticket
POSTGRES_PASSWORD=change-me
POSTGRES_DB=whaticket

# --- RabbitMQ --------------------------------------------------------------
RABBITMQ_USER=whaticket
RABBITMQ_PASSWORD=change-me

# --- MinIO (S3-compatible media storage) -----------------------------------
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_BUCKET=whaticket-media
# Public URL exposed by Traefik for the MinIO endpoint (used to build media
# links the browser fetches directly).
MINIO_PUBLIC_URL=https://storage.example.com

# --- JWT (32+ random bytes each) -------------------------------------------
JWT_SECRET=replace-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-secret

# --- Frontend wiring -------------------------------------------------------
# URL the backend uses to build CORS/cookie-domain logic.
FRONTEND_URL=https://app.example.com
# URL the browser uses to reach the backend REST/WS API.
FRONTEND_BACKEND_URL=https://api.example.com

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=info
