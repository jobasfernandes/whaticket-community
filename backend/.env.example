# ===========================================================================
# Whaticket backend (Go) — environment reference
# ---------------------------------------------------------------------------
# All variables read by cmd/server, cmd/migrate and cmd/seed.
# Defaults shown after the `=` are what the binary falls back to when the
# variable is unset.
# ===========================================================================

# --- HTTP server -----------------------------------------------------------
BACKEND_LISTEN_ADDR=:8080
LOG_LEVEL=info

# --- Database (Postgres 14+) -----------------------------------------------
# DATABASE_URL is preferred; POSTGRES_DSN is accepted as fallback.
DATABASE_URL=postgres://whaticket:whaticket@postgres:5432/whaticket?sslmode=disable

# --- Boot-time hooks (default: false in the binary) ------------------------
# AUTO_MIGRATE runs Goose `up` on startup. Safe to re-run.
# AUTO_SEED ensures the admin user and `userCreation` setting exist.
AUTO_MIGRATE=false
AUTO_SEED=false
SEED_ADMIN_EMAIL=admin@whaticket.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=admin

# --- JWT (32+ random bytes each) -------------------------------------------
JWT_SECRET=please-change-this-to-a-32-byte-random-string
JWT_REFRESH_SECRET=another-32-byte-random-string-for-refresh-tokens

# --- RabbitMQ --------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- S3 / MinIO (outbound media uploads) -----------------------------------
BACKEND_S3_ENDPOINT=minio:9000
BACKEND_S3_ACCESS_KEY=minioadmin
BACKEND_S3_SECRET_KEY=minioadmin
BACKEND_S3_BUCKET=whaticket-media
BACKEND_S3_PUBLIC_URL=http://localhost:9000
BACKEND_S3_USE_SSL=false

# --- CORS / cookie domain --------------------------------------------------
FRONTEND_URL=http://localhost:3000
