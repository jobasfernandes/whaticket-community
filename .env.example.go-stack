# === Go stack production compose ===
# Used by: docker-compose.go.prod.yaml
# Copy this to .env and fill in real values.

# Image tags (set to a specific tag in CI; "latest" for local prod tests)
BACKEND_TAG=latest
WORKER_TAG=latest
FRONTEND_TAG=latest

# Hostnames (DNS records must point at the Traefik host)
BACKEND_HOST=api.example.com
FRONTEND_HOST=app.example.com
MINIO_HOST=storage.example.com

# Let's Encrypt ACME contact
ACME_EMAIL=ops@example.com

# Postgres
POSTGRES_USER=whaticket
POSTGRES_PASSWORD=please-change-this
POSTGRES_DB=whaticket

# RabbitMQ
RABBITMQ_USER=whaticket
RABBITMQ_PASSWORD=please-change-this

# MinIO (S3)
MINIO_ROOT_USER=please-change-this
MINIO_ROOT_PASSWORD=please-change-this-min-8-chars
MINIO_BUCKET=whaticket-media
MINIO_PUBLIC_URL=https://storage.example.com

# JWT (32+ random bytes each)
JWT_SECRET=replace-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-secret

# Frontend integration
FRONTEND_URL=https://app.example.com
FRONTEND_BACKEND_URL=https://api.example.com

# Logging
LOG_LEVEL=info
